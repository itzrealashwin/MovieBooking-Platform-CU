{
	"info": {
		"_postman_id": "movie-booking-platform-cu-full",
		"name": "MovieBooking Platform CU — Full API Suite",
		"description": "Complete API test suite for the MovieBooking Platform. Covers Auth, Movies, Theatres, Screens, Showtimes, Seats (Redis locking), Bookings, and Payments.\n\n**Setup:**\n1. Import this collection\n2. Set the `baseUrl` variable (default: http://localhost:5000)\n3. Run '1. Register' then '2. Login' — the token auto-populates\n4. Run '3. Admin Login' for admin-only routes\n5. Follow the numbered folders in order for a full lifecycle test",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
		{ "key": "accessToken", "value": "", "type": "string" },
		{ "key": "adminToken", "value": "", "type": "string" },
		{ "key": "refreshToken", "value": "", "type": "string" },
		{ "key": "userId", "value": "", "type": "string" },
		{ "key": "movieId", "value": "", "type": "string" },
		{ "key": "theatreId", "value": "", "type": "string" },
		{ "key": "screenId", "value": "", "type": "string" },
		{ "key": "showtimeId", "value": "", "type": "string" },
		{ "key": "bookingId", "value": "", "type": "string" },
		{ "key": "paymentTransactionId", "value": "", "type": "string" }
	],
	"item": [
		{
			"name": "0. Health Check",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api", "health"] }
					}
				}
			]
		},
		{
			"name": "1. Auth",
			"item": [
				{
					"name": "Register User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"  const body = pm.response.json();",
									"  if (body.data && body.data.accessToken) {",
									"    pm.collectionVariables.set('accessToken', body.data.accessToken);",
									"  }",
									"  if (body.data && body.data.refreshToken) {",
									"    pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
									"  }",
									"  if (body.data && body.data.user && body.data.user._id) {",
									"    pm.collectionVariables.set('userId', body.data.user._id);",
									"  }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Test@1234\",\n  \"phone\": \"9876543210\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
					}
				},
				{
					"name": "Login User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"  const body = pm.response.json();",
									"  if (body.data && body.data.accessToken) {",
									"    pm.collectionVariables.set('accessToken', body.data.accessToken);",
									"  }",
									"  if (body.data && body.data.refreshToken) {",
									"    pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
									"  }",
									"  if (body.data && body.data.user && body.data.user._id) {",
									"    pm.collectionVariables.set('userId', body.data.user._id);",
									"  }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Test@1234\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
					}
